{
  "name": "jackdaw",
  "version": "0.0.1",
  "description": "JackDaw1",
  "main": "glint_meson.js",
  "bin": "glint_meson.js",
  "scripts": {
    "start": "node glint_meson.js",
    "dev": "node glint_meson.js",
    "lint": "eslint .",
    "build:win": "pkg . --targets node18-win-x64 --out-path dist",
    "build:linux": "pkg . --targets node18-linux-x64 --out-path dist",
    "build:mac": "pkg . --targets node18-macos-x64 --out-path dist",
    "build:all": "pkg . --out-path dist"
  },
  "keywords": [
    "headless",
    "chrome",
    "crawler",
    "test-automation"
  ],
  "author": "Wrench",
  "engines": {
    "node": ">=4"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.8.11",
    "axios": "^1.13.6",
    "bluebird": "^3.7.2",
    "chrome-launcher": "^1.2.1",
    "chrome-remote-interface": "^0.34.0",
    "cssesc": "^3.0.0",
    "deepmerge": "^4.3.1",
    "lodash": "^4.17.21",
    "minimist": "^1.2.8",
    "mz": "^2.7.0",
    "playwright": "^1.58.2",
    "puppeteer": "^24.26.1",
    "react-dropzone": "^15.0.0"
  },
  "pkg": {
    "assets": [
      "plugins/**/*.js",
      "core/**/*.js",
      "lib/**/*.js",
      "load/**/*.js",
      "utils/**/*.js",
      "mesonrpc/**/*.proto",
      "dom_xss_detector.js"
    ],
    "targets": [
      "node18-win-x64",
      "node18-linux-x64",
      "node18-macos-x64"
    ],
    "outputPath": "dist"
  }
}
